# Production site URL (used for QR code generation)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# GitHub API — required on Vercel so visitor requests can be saved
# Create a fine-grained PAT with Contents: Read and write on this repo
GITHUB_TOKEN=
GITHUB_REPO=your-username/cursor-fun

# Admin token — protects the canvas reset button in /studio.
# If unset, reset is unprotected (fine for local dev only).
ADMIN_TOKEN=
